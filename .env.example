# Database — injected automatically by Node.js Hosting (GoDaddy managed MySQL)
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# JWT — set a strong random string (64+ characters) via the hosting UI
JWT_SECRET=
JWT_EXPIRES_IN=8h

# Server
NODE_ENV=production
PORT=3000

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
